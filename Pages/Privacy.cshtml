@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Privacy</p>
        <h1>Private by default</h1>
        <p class="lead">Only the two seeded accounts can access the app. Production passwords belong in environment variables.</p>
    </div>
</section>

<section class="notes-band">
    <p><strong>Authentication</strong><br />ASP.NET Core Identity keeps each score attached to the person who entered it.</p>
    <p><strong>Hosting</strong><br />SQLite stays simple for now, but the database file should be backed up if this becomes your real shared record.</p>
</section>
