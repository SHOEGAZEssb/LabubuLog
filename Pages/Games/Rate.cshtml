@page "{id:int}/rate"
@model LabubuLog.Pages.Games.RateModel
@{
    ViewData["Title"] = "Rate game";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Ratings</p>
        <h1>@Model.Game.Title</h1>
    </div>
</section>

<form method="post" class="edit-surface compact-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-grid">
        <div class="form-floating wide">
            <input class="form-control" asp-for="Input.Score" placeholder="@Model.ScoreLabel" />
            <label asp-for="Input.Score">@Model.ScoreLabel</label>
            <span class="text-danger" asp-validation-for="Input.Score"></span>
        </div>
        <div class="form-floating wide">
            <textarea class="form-control tall-input" asp-for="Input.FavoriteMoment" placeholder="Favorite moment"></textarea>
            <label asp-for="Input.FavoriteMoment"></label>
            <span class="text-danger" asp-validation-for="Input.FavoriteMoment"></span>
        </div>
        <div class="form-floating wide">
            <textarea class="form-control tall-input" asp-for="Input.Notes" placeholder="Notes"></textarea>
            <label asp-for="Input.Notes"></label>
            <span class="text-danger" asp-validation-for="Input.Notes"></span>
        </div>
    </div>
    <div class="form-actions">
        <button class="btn btn-primary" type="submit">Save scores</button>
        <a class="btn btn-outline-secondary" asp-page="Details" asp-route-id="@Model.Game.Id">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
