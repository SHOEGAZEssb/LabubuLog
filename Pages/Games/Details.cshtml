@page "{id:int}"
@model LabubuLog.Pages.Games.DetailsModel
@{
    ViewData["Title"] = Model.Game.Title;
}

<section class="detail-layout">
    <aside class="detail-cover">
        <div class="cover-frame large">
            @if (!string.IsNullOrWhiteSpace(Model.Game.CoverImageUrl))
            {
                <img src="@Model.Game.CoverImageUrl" alt="@Model.Game.Title cover" />
            }
            else
            {
                <span>@Model.Game.Title[0]</span>
            }
        </div>
    </aside>
    <div class="detail-content">
        <div class="page-heading detail-heading">
            <div>
                <p class="eyebrow">@Model.Game.Status</p>
                <h1>@Model.Game.Title</h1>
                <p class="lead">
                    @Model.Game.Platform
                    @if (!string.IsNullOrWhiteSpace(Model.Game.Genre))
                    {
                        <span>/ @Model.Game.Genre</span>
                    }
                    @if (Model.Game.ReleaseYear.HasValue)
                    {
                        <span>/ @Model.Game.ReleaseYear</span>
                    }
                </p>
            </div>
            <div class="heading-actions">
                <a class="btn btn-outline-primary" asp-page="Rate" asp-route-id="@Model.Game.Id">Rate</a>
                <a class="btn btn-outline-secondary" asp-page="Edit" asp-route-id="@Model.Game.Id">Edit metadata</a>
                <a class="btn btn-outline-danger" asp-page="Delete" asp-route-id="@Model.Game.Id">Delete</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Game.TitleImageUrl))
        {
            <section class="title-image-frame" aria-label="@Model.Game.Title title image">
                <img src="@Model.Game.TitleImageUrl" alt="@Model.Game.Title title image" />
            </section>
        }

        <section class="rating-detail-grid">
            <div class="rating-column">
                <div class="rating-tile score-tile" style="@ScoreDisplay.HueStyle(Model.SharedScore)">
                    <span>Shared score</span>
                    <strong>@(Model.SharedScore?.ToString("0.0") ?? "-")</strong>
                </div>
            </div>
            @foreach (var score in Model.Scores)
            {
                <div class="rating-column">
                    <div class="rating-tile score-tile" style="@ScoreDisplay.HueStyle(score.Score)">
                        <span>@score.ScoreLabel</span>
                        <strong>@(score.Score?.ToString() ?? "-")</strong>
                    </div>
                    <article class="rating-note-card">
                        <h2>@score.DisplayName</h2>
                        <p>
                            <strong>Favorite moment</strong><br />
                            @score.FavoriteMoment
                        </p>
                        <p>
                            <strong>Notes</strong><br />
                            @score.Notes
                        </p>
                    </article>
                </div>
            }
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.Game.Tags))
        {
            <section class="notes-band">
                <p><strong>Tags</strong><br />@Model.Game.Tags</p>
            </section>
        }

    </div>
</section>
